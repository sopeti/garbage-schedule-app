{
  "expo": {
    "name": "ゴミ出しカレンダー",
    "slug": "garbage-schedule-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gomiapp",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f4f0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sopeti.garbageschedule",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "ゴミの日をお知らせします"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0f4f0"
      },
      "package": "com.sopeti.garbageschedule"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#4a9e5c"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
